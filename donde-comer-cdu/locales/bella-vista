<script>
(function(){
  'use strict';

  /* ── ESTADO ABIERTO / CERRADO ── */
  (function(){
    var ahora = new Date(new Date().toLocaleString('en-US',{timeZone:'America/Argentina/Buenos_Aires'}));
    var dia   = ahora.getDay();
    var hora  = ahora.getHours() + ahora.getMinutes()/60;
    var openColor='#40916c', openBg='rgba(64,145,108,0.15)';
    var closedColor='#c1121f', closedBg='rgba(193,18,31,0.12)';

    function setStatus(open, sub){
      var pill=document.getElementById('schedStatusPill');
      var text=document.getElementById('schedStatusText');
      var dot =document.getElementById('schedDot');
      var info=document.getElementById('schedInfo');
      var val =document.getElementById('statusValue');
      var subEl=document.getElementById('statusSub');
      var c=open?openColor:closedColor, bg=open?openBg:closedBg;
      pill.style.background=bg; pill.style.color=c;
      dot.style.background=c;
      text.textContent=open?'Abierto ahora':'Cerrado';
      if(val){val.textContent=open?'Abierto ahora':'Cerrado';val.style.color=c;}
      if(info)info.textContent=sub;
      if(subEl)subEl.textContent=sub;
    }

    if(dia===1){
      setStatus(false,'Cerrado hoy. Abre mañana a las 08:00 hs.');
    } else if(hora>=8 && hora<24){
      var minsLeft=Math.round((24-hora)*60);
      setStatus(true, minsLeft<=60?'Cierra en '+minsLeft+' min':'Cierra a las 00:00 hs.');
    } else {
      setStatus(false,'Abre a las 08:00 hs.');
    }
  })();

  /* ── BARRAS de score: animar al hacer scroll ── */
  var fills=document.querySelectorAll('.score-fill');
  fills.forEach(function(f){f.style.width=f.dataset.width;});
  var scoreSection=document.querySelector('.scores-section');
  if(scoreSection){
    var sio=new IntersectionObserver(function(entries){
      if(entries[0].isIntersecting){
        fills.forEach(function(f,i){
          setTimeout(function(){f.classList.add('animated');},i*150);
        });
        sio.disconnect();
      }
    },{threshold:.3});
    sio.observe(scoreSection);
  }

  /* ── SHARE ── */
  var shareBtn=document.getElementById('share-btn');
  if(shareBtn){
    shareBtn.addEventListener('click',function(){
      if(navigator.share){
        navigator.share({
          title:'Bella Vista — URU SPOT',
          text:'¡Mirá este lugar en Concepción del Uruguay! Clásico, familiar y con vistas.',
          url:window.location.href
        }).catch(function(){});
      } else {
        navigator.clipboard.writeText(window.location.href).then(function(){
          shareBtn.textContent='✓ Link copiado';
          setTimeout(function(){shareBtn.innerHTML='📤 Compartir';},2000);
        });
      }
    });
  }

})();
</script>
