<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --gold:#c9a84c;--gold-light:#e8d5a3;--gold-dark:#8a6820;
  --ink:#0d0d0d;--ink-soft:#1a1a1a;--cream:#faf7f2;--cream-deep:#f0ebe0;
  --muted:#6b6459;--green-accent:#2d6a4f;--green-bright:#40916c;
  --red-accent:#c1121f;--border:rgba(201,168,76,0.25);
}
html{scroll-behavior:smooth}
body{background:var(--cream);color:var(--ink);font-family:'DM Sans',sans-serif;font-weight:300;-webkit-font-smoothing:antialiased;overflow-x:hidden}

/* NAV */
.nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:18px 48px;background:rgba(250,247,242,0.92);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid var(--border)}
.nav-logo{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:600;letter-spacing:0.12em;color:var(--gold-dark);text-decoration:none;text-transform:uppercase}
.nav-tag{font-size:11px;letter-spacing:0.2em;color:var(--muted);text-transform:uppercase;font-weight:500}
.nav-badge{background:var(--gold);color:var(--ink);font-size:10px;font-weight:600;letter-spacing:0.15em;padding:5px 14px;border-radius:2px;text-transform:uppercase}

/* HERO */
.hero{position:relative;height:100vh;min-height:600px;overflow:hidden;display:flex;flex-direction:column;justify-content:flex-end}
.hero-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transform:scale(1.06);transition:transform 8s ease;filter:brightness(0.7) saturate(0.9)}
.hero:hover .hero-img{transform:scale(1.02)}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(13,13,13,0.95) 0%,rgba(13,13,13,0.4) 50%,rgba(13,13,13,0.1) 100%)}
.hero-content{position:relative;z-index:2;padding:0 72px 72px;max-width:900px}
.hero-eyebrow{display:flex;align-items:center;gap:16px;margin-bottom:20px}
.eyebrow-line{width:48px;height:1px;background:var(--gold)}
.eyebrow-text{font-size:11px;letter-spacing:0.3em;color:var(--gold);text-transform:uppercase;font-weight:500}
.hero-title{font-family:'Cormorant Garamond',serif;font-size:clamp(64px,10vw,120px);font-weight:300;color:#fff;line-height:0.9;letter-spacing:-0.02em;margin-bottom:24px}
.hero-title em{font-style:italic;color:var(--gold-light)}
.hero-subtitle{font-size:15px;color:rgba(255,255,255,0.7);font-weight:300;letter-spacing:0.05em;max-width:480px;line-height:1.6;margin-bottom:36px}
.hero-chips{display:flex;flex-wrap:wrap;gap:10px}
.chip{padding:8px 18px;border:1px solid rgba(201,168,76,0.4);border-radius:2px;font-size:12px;letter-spacing:0.12em;color:rgba(255,255,255,0.85);text-transform:uppercase;font-weight:400;background:rgba(201,168,76,0.08)}
.chip-gold{background:var(--gold);color:var(--ink);border-color:var(--gold);font-weight:600}
.hero-score{position:absolute;top:50%;right:72px;transform:translateY(-50%);z-index:2;text-align:center;border:1px solid rgba(201,168,76,0.3);padding:28px 32px;background:rgba(13,13,13,0.6);backdrop-filter:blur(12px)}
.score-num{font-family:'Cormorant Garamond',serif;font-size:64px;font-weight:300;color:var(--gold);line-height:1}
.score-label{font-size:10px;letter-spacing:0.3em;color:rgba(255,255,255,0.5);text-transform:uppercase;margin-top:4px}
.score-stars{color:var(--gold);font-size:14px;margin-top:8px}

/* INFO STRIP */
.info-strip{background:var(--ink-soft);color:#fff;display:grid;grid-template-columns:repeat(3,1fr)}
.info-cell{padding:32px 40px;border-right:1px solid rgba(255,255,255,0.08);display:flex;flex-direction:column;gap:6px}
.info-cell:last-child{border-right:none}
.info-cell-label{font-size:10px;letter-spacing:0.3em;color:var(--gold);text-transform:uppercase;font-weight:500}
.info-cell-value{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:400;color:#fff}
.info-cell-sub{font-size:12px;color:rgba(255,255,255,0.4);letter-spacing:0.05em}

/* STATUS PILL */
.status-pill{display:inline-flex;align-items:center;gap:7px;padding:6px 14px;border-radius:2px;font-size:11px;font-weight:600;letter-spacing:0.15em;text-transform:uppercase}
.status-dot{width:6px;height:6px;border-radius:50%}

/* ACTIONS */
.action-row{display:flex;gap:10px;margin-top:16px;flex-wrap:wrap}
.btn{display:inline-flex;align-items:center;gap:8px;padding:12px 22px;border-radius:2px;font-size:12px;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;text-decoration:none;transition:opacity .2s,transform .15s;cursor:pointer;border:none;font-family:'DM Sans',sans-serif}
.btn:hover{opacity:.85;transform:translateY(-1px)}
.btn:active{transform:translateY(0)}
.btn-primary{background:var(--gold);color:var(--ink)}
.btn-ghost{background:transparent;color:#fff;border:1px solid rgba(255,255,255,0.3)}
.btn-ghost:hover{border-color:var(--gold);color:var(--gold)}
.btn-dark{background:var(--ink);color:#fff;border:1px solid rgba(255,255,255,0.1)}

/* MAIN LAYOUT */
.page{max-width:1200px;margin:0 auto;padding:80px 48px}

/* SECTION HEADER */
.section-header{display:flex;align-items:center;gap:20px;margin-bottom:48px}
.section-line{flex:1;height:1px;background:var(--border)}
.section-label{font-size:10px;letter-spacing:0.35em;color:var(--gold-dark);text-transform:uppercase;font-weight:600;white-space:nowrap}

/* ABOUT */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start}
.about-title{font-family:'Cormorant Garamond',serif;font-size:clamp(36px,4vw,52px);font-weight:300;line-height:1.1;color:var(--ink);margin-bottom:28px}
.about-title strong{font-weight:600}
.about-body{font-size:15px;line-height:1.85;color:var(--muted);font-weight:300;margin-bottom:20px}
.pullquote{border-left:3px solid var(--gold);padding:20px 28px;margin:32px 0;background:var(--cream-deep)}
.pullquote p{font-family:'Cormorant Garamond',serif;font-size:22px;font-style:italic;font-weight:300;color:var(--ink);line-height:1.5}

/* GALLERY */
.gallery{display:grid;grid-template-columns:2fr 1fr;grid-template-rows:240px 240px;gap:4px;border-radius:4px;overflow:hidden}
.gallery-main{grid-row:1/3}
.gallery img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s;filter:brightness(0.9) saturate(0.95)}
.gallery-item{overflow:hidden}
.gallery-item:hover img{transform:scale(1.04)}

/* TAGS */
.tags-row{display:flex;flex-wrap:wrap;gap:8px;margin-top:28px}
.tag{padding:7px 16px;border:1px solid var(--border);font-size:11px;letter-spacing:0.12em;color:var(--muted);text-transform:uppercase;font-weight:400;border-radius:2px}

/* HIGHLIGHTS */
.highlights-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.highlight-card{background:var(--ink);color:#fff;padding:36px 32px;position:relative;overflow:hidden;transition:background .3s}
.highlight-card:hover{background:var(--ink-soft)}
.highlight-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--gold);opacity:0;transition:opacity .3s}
.highlight-card:hover::before{opacity:1}
.highlight-num{font-family:'Cormorant Garamond',serif;font-size:48px;font-weight:300;color:rgba(201,168,76,0.15);line-height:1;margin-bottom:12px}
.highlight-title{font-size:13px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:#fff;margin-bottom:8px}
.highlight-text{font-size:13px;color:rgba(255,255,255,0.5);line-height:1.6}

/* SCORES */
.scores-section{background:var(--cream-deep);padding:80px 48px}
.scores-inner{max-width:1200px;margin:0 auto}
.scores-grid{display:grid;grid-template-columns:1fr 2fr;gap:64px;align-items:center}
.score-big{text-align:center;padding:48px;border:1px solid var(--border);background:var(--cream)}
.score-big-num{font-family:'Cormorant Garamond',serif;font-size:100px;font-weight:300;color:var(--gold);line-height:1}
.score-big-den{font-size:18px;color:var(--muted);font-weight:300;margin-top:4px}
.score-big-label{font-size:10px;letter-spacing:0.35em;color:var(--muted);text-transform:uppercase;margin-top:16px;font-weight:500}
.score-bars{display:flex;flex-direction:column;gap:28px}
.score-row-top{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px}
.score-name{font-size:13px;font-weight:500;color:var(--ink);letter-spacing:0.05em}
.score-val{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:300;color:var(--gold-dark)}
.score-track{height:3px;background:rgba(0,0,0,0.08);border-radius:0}
.score-fill{height:3px;background:var(--gold);border-radius:0;transform-origin:left;transform:scaleX(0);transition:transform 1.2s cubic-bezier(.16,1,.3,1)}
.score-fill.animated{transform:scaleX(1)}

/* HORARIOS BLOCK */
.schedule-block{background:var(--ink);color:#fff;padding:64px 72px;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
.schedule-title{font-family:'Cormorant Garamond',serif;font-size:42px;font-weight:300;margin-bottom:24px;color:#fff;line-height:1.1}
.schedule-row{display:flex;justify-content:space-between;align-items:center;padding:14px 0;border-bottom:1px solid rgba(255,255,255,0.06);font-size:14px}
.schedule-row:last-of-type{border-bottom:none}
.schedule-day{color:rgba(255,255,255,0.5);font-weight:300}
.schedule-time{color:#fff;font-weight:400}
.schedule-time-closed{color:var(--red-accent);font-weight:400}
.schedule-price-block{padding:28px;border:1px solid rgba(201,168,76,0.2);margin-top:24px}
.schedule-price-label{font-size:10px;letter-spacing:0.3em;color:var(--gold);text-transform:uppercase;margin-bottom:8px}
.schedule-price-val{font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:300;color:#fff;margin-bottom:4px}
.schedule-price-usd{font-size:12px;color:rgba(255,255,255,0.4)}

/* MAPA */
.map-section{background:var(--cream-deep);padding:80px 48px}
.map-inner{max-width:1200px;margin:0 auto}
.map-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
.map-frame{height:340px;border-radius:2px;overflow:hidden;border:1px solid var(--border)}
.map-frame iframe{width:100%;height:100%;border:none}
.map-info-title{font-family:'Cormorant Garamond',serif;font-size:36px;font-weight:300;margin-bottom:20px;line-height:1.2}
.map-detail{font-size:14px;color:var(--muted);line-height:1.7;margin-bottom:8px}
.map-detail strong{color:var(--ink);font-weight:500}

/* VERDICT */
.verdict-section{padding:80px 48px}
.verdict-inner{max-width:1200px;margin:0 auto}
.verdict-card{display:grid;grid-template-columns:auto 1fr;gap:0;border:1px solid var(--border);overflow:hidden}
.verdict-accent{width:8px;background:var(--gold)}
.verdict-content{padding:48px 56px}
.verdict-label{font-size:10px;letter-spacing:0.35em;color:var(--gold-dark);text-transform:uppercase;font-weight:600;margin-bottom:16px}
.verdict-text{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:300;line-height:1.45;color:var(--ink)}

/* FOOTER */
.footer{background:var(--ink);color:rgba(255,255,255,0.4);padding:40px 48px;display:flex;justify-content:space-between;align-items:center;font-size:12px;letter-spacing:0.08em}
.footer-logo{font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:600;color:var(--gold);letter-spacing:0.1em;text-decoration:none;text-transform:uppercase}

/* MOBILE */
@media(max-width:768px){
  .nav{padding:16px 20px}
  .nav-tag,.nav-badge{display:none}
  .hero-content{padding:0 20px 44px}
  .hero-score{display:none}
  .page{padding:48px 20px}
  .about-grid,.scores-grid,.map-grid{grid-template-columns:1fr;gap:32px}
  .gallery{grid-template-columns:1fr;grid-template-rows:auto}
  .gallery-main{grid-row:auto}
  .gallery img{height:220px}
  .highlights-grid{grid-template-columns:1fr}
  .highlight-card{padding:28px 20px}
  .schedule-block{grid-template-columns:1fr;padding:44px 20px;gap:32px}
  .info-strip{grid-template-columns:1fr}
  .info-cell{border-right:none;border-bottom:1px solid rgba(255,255,255,0.08);padding:24px 20px}
  .map-grid{grid-template-columns:1fr}
  .verdict-content{padding:28px 24px}
  .verdict-text{font-size:22px}
  .footer{flex-direction:column;gap:14px;text-align:center;padding:32px 20px}
  .scores-section,.map-section,.verdict-section{padding:52px 20px}
  .score-big{padding:32px 20px}
  .score-big-num{font-size:80px}
  .section-header{margin-bottom:32px}
  .action-row{flex-direction:column}
  .btn{justify-content:center}
  .hero-title{font-size:clamp(52px,13vw,90px)}
  .map-frame{height:260px}
}
@media(max-width:480px){
  .hero-chips .chip{font-size:10px;padding:6px 12px}
  .about-title{font-size:32px}
  .schedule-block{padding:36px 16px}
  .schedule-title{font-size:32px}
}
@media(prefers-reduced-motion:reduce){
  *,*::before,*::after{animation-duration:.001ms!important;transition-duration:.001ms!important}
  .score-fill{transform:scaleX(1)}
}
</style>
</head>
